{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/fundraising/**",
              "poc/**",
              "ui_kits/workspace/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Newsreader|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Newsreader, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AISuggestion'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|source|from|to|onApprove|onEdit|onDismiss|key|ref|className|style|children)$/]",
        "message": "<AISuggestion> doesn't accept that prop. Declared props: children, source, from, to, onApprove, onEdit, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|kind|ringColor|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, kind, ringColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:person|org)$/]",
        "message": "<Avatar> kind must be one of 'person' | 'org'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|solid|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, solid, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|elevation|pad|accent|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, elevation, pad, accent, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|ai|go|sunk)$/]",
        "message": "<Card> tone must be one of 'default' | 'ai' | 'go' | 'sunk'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:none|sm|md)$/]",
        "message": "<Card> elevation must be one of 'none' | 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HorizonTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:horizon|solid|key|ref|className|style|children)$/]",
        "message": "<HorizonTag> doesn't accept that prop. Declared props: horizon, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='HorizonTag'] > JSXAttribute[name.name='horizon'] > Literal[value!=/^(?:today|tomorrow|forever)$/]",
        "message": "<HorizonTag> horizon must be one of 'today' | 'tomorrow' | 'forever'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|optional|hint|error|icon|ai|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, optional, hint, error, icon, ai."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProspectRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|name|kind|subtitle|qpi|horizon|manager|partner|cadence|dueSoon|interactive|key|ref|className|style|children)$/]",
        "message": "<ProspectRow> doesn't accept that prop. Declared props: rank, name, kind, subtitle, qpi, horizon, manager, partner, cadence, dueSoon, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProspectRow'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:person|company|foundation)$/]",
        "message": "<ProspectRow> kind must be one of 'person' | 'company' | 'foundation'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProspectRow'] > JSXAttribute[name.name='horizon'] > Literal[value!=/^(?:today|tomorrow|forever)$/]",
        "message": "<ProspectRow> horizon must be one of 'today' | 'tomorrow' | 'forever'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QPIPart'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|max|reason|source|key|ref|className|style|children)$/]",
        "message": "<QPIPart> doesn't accept that prop. Declared props: score, max, reason, source."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|name|key|ref|className|style|children)$/]",
        "message": "<RoleChip> doesn't accept that prop. Declared props: role, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleChip'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:manager|partner)$/]",
        "message": "<RoleChip> role must be one of 'manager' | 'partner'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|label|onClick|key|ref|className|style|children)$/]",
        "message": "<SourceTag> doesn't accept that prop. Declared props: source, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|selected|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: color, selected, onRemove, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
