# Copy to .env and adjust. Consumed by docker-compose, packages/db, and the apps.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# DATABASE_URL: the owner/superuser role. Used by migrate/seed and by getCurrentUser()
# auth resolution; bypasses Row-Level Security. Matches docker-compose.yml (forward).
DATABASE_URL=postgres://forward:forward@localhost:5432/forward
# APP_DATABASE_URL: the app runtime role (app_user, NON-superuser). All feature data
# access uses this; it is subject to RLS tenant isolation. The app_user role + policies
# are created by migration 0004. (Use a strong password in production.)
APP_DATABASE_URL=postgres://app_user:app_user@localhost:5432/forward

# ── Services ─────────────────────────────────────────────────────────────────
WORKER_PORT=3001

# ── Web (Next.js public vars) ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=95 Forward
NEXT_PUBLIC_HOST_NAME=Keystone CRM
NEXT_PUBLIC_HOST_ORG=Water For People

# ── Auth0 (REQUIRED — Initiative 1) ──────────────────────────────────────────
# Create a "Regular Web Application" in the Auth0 dashboard. AUTH0_DOMAIN is the
# tenant domain with no scheme. Generate AUTH0_SECRET with: openssl rand -hex 32
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# E2E test seams: when "true" (and NODE_ENV != production) the gated /api/test-login
# (mints a session for a seeded user, no live Auth0) and /api/test-drain-jobs (drains
# the job queue synchronously) routes are reachable — used by Playwright and local dev.
# MUST stay "false"/unset in production; the seams also hard-refuse when NODE_ENV=production.
E2E_TEST_MODE=false

# ── AI Foundation (Initiative 6) ─────────────────────────────────────────────
# AI_MODE selects the model + research/embedding providers. "mock" (default) uses
# deterministic stand-ins and needs NO API keys — this is what CI and local dev use.
# "live" calls real providers and REQUIRES the keys below.
AI_MODE=mock
# RESEARCH_MODE: "demo" returns seeded OSINT candidates (safe/deterministic); "live"
# (Initiative 11) performs real web research.
RESEARCH_MODE=demo
# EMBEDDING_MODE: defaults to AI_MODE. Set "live" to backfill real OpenAI embeddings
# while keeping the model on mock (e.g. EMBEDDING_MODE=live with OPENAI_API_KEY set).
# EMBEDDING_MODE=mock
EMBEDDINGS_MODEL=text-embedding-3-small
# Required only in live mode (set manually in real environments):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── In-app feedback → GitHub issue (Initiative 15) ───────────────────────────
# FEEDBACK_MODE: "mock" (default) composes + validates the issue payload and returns
# a synthetic reference WITHOUT calling GitHub — this is what CI, E2E, and local dev use.
# "live" submits a real GitHub issue and REQUIRES the token + repo below.
FEEDBACK_MODE=mock
# FEEDBACK_REPO: owner/repo the issue is filed against (server-controlled, never hardcoded).
# FEEDBACK_REPO=Aztherion/95Forward-PoC
# FEEDBACK_GITHUB_TOKEN: a DEDICATED fine-grained PAT, this repo only, Issues: Read & Write
# only (no Contents, no Pull requests). Distinct from any CI bot token. Server-only secret —
# never exposed to the browser. Required only in live mode.
# FEEDBACK_GITHUB_TOKEN=
# FEEDBACK_ENABLED: optional hard-off switch for the widget without a redeploy (true|false).
# When unset, the widget shows whenever it is configured (live mode with token+repo, or mock).
# FEEDBACK_ENABLED=true
# NEXT_PUBLIC_BUILD_SHA: short commit SHA of the deployed build, captured at build time and
# included in the feedback context block. Falls back to "unknown" if unset.
# NEXT_PUBLIC_BUILD_SHA=

# ── Background jobs (Initiative 11 — worker only) ────────────────────────────
# The worker runs with its OWN minimal env (validated by getWorkerEnv): the two DB
# URLs above + the AI mode vars + these. It does NOT require the Auth0 vars (those
# are web-only, validated by getEnv). Graphile Worker reuses DATABASE_URL (owner)
# for its own graphile_worker schema; job handlers reach tenant data via
# APP_DATABASE_URL under RLS.
JOBS_CONCURRENCY=3
JOBS_SCHEMA=graphile_worker
