# Copy to .env and adjust. Consumed by docker-compose, packages/db, and the apps.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Matches docker-compose.yml (user / password / db all = "forward").
DATABASE_URL=postgres://forward:forward@localhost:5432/forward

# ── Services ─────────────────────────────────────────────────────────────────
WORKER_PORT=3001

# ── Web (Next.js public vars) ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=95 Forward
NEXT_PUBLIC_HOST_NAME=Keystone CRM
NEXT_PUBLIC_HOST_ORG=Water For People

# ─────────────────────────────────────────────────────────────────────────────
# LATER INITIATIVES — placeholders only (NOT required in Initiative 0).
# Uncomment + fill as each initiative lands.
#
# Initiative 1 — Auth0 authentication
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=
# APP_BASE_URL=http://localhost:3000
#
# Initiative 6 — AI / embeddings / retrieval
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# EMBEDDINGS_MODEL=
#
# Initiative 11 — background jobs (Graphile Worker reuses DATABASE_URL)
# JOBS_CONCURRENCY=4
# JOBS_SCHEMA=graphile_worker
