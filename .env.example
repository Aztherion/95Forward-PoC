# Copy to .env and adjust. Consumed by docker-compose, packages/db, and the apps.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# DATABASE_URL: the owner/superuser role. Used by migrate/seed and by getCurrentUser()
# auth resolution; bypasses Row-Level Security. Matches docker-compose.yml (forward).
DATABASE_URL=postgres://forward:forward@localhost:5432/forward
# APP_DATABASE_URL: the app runtime role (app_user, NON-superuser). All feature data
# access uses this; it is subject to RLS tenant isolation. The app_user role + policies
# are created by migration 0004. (Use a strong password in production.)
APP_DATABASE_URL=postgres://app_user:app_user@localhost:5432/forward

# ── Services ─────────────────────────────────────────────────────────────────
WORKER_PORT=3001

# ── Web (Next.js public vars) ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=95 Forward
NEXT_PUBLIC_HOST_NAME=Keystone CRM
NEXT_PUBLIC_HOST_ORG=Water For People

# ── Auth0 (REQUIRED — Initiative 1) ──────────────────────────────────────────
# Create a "Regular Web Application" in the Auth0 dashboard. AUTH0_DOMAIN is the
# tenant domain with no scheme. Generate AUTH0_SECRET with: openssl rand -hex 32
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Dev/test login seam: when "true" (and NODE_ENV != production) a gated
# /api/test-login route mints a session for a seeded user with NO live Auth0
# tenant — used by Playwright and local dev. MUST stay "false" in production.
AUTH_DEV_LOGIN=false

# ── AI Foundation (Initiative 6) ─────────────────────────────────────────────
# AI_MODE selects the model + research/embedding providers. "mock" (default) uses
# deterministic stand-ins and needs NO API keys — this is what CI and local dev use.
# "live" calls real providers and REQUIRES the keys below.
AI_MODE=mock
# RESEARCH_MODE: "demo" returns seeded OSINT candidates (safe/deterministic); "live"
# (Initiative 11) performs real web research.
RESEARCH_MODE=demo
# EMBEDDING_MODE: defaults to AI_MODE. Set "live" to backfill real OpenAI embeddings
# while keeping the model on mock (e.g. EMBEDDING_MODE=live with OPENAI_API_KEY set).
# EMBEDDING_MODE=mock
EMBEDDINGS_MODEL=text-embedding-3-small
# Required only in live mode (set manually in real environments):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# LATER INITIATIVE — placeholders only.
#
# Initiative 11 — background jobs (Graphile Worker reuses DATABASE_URL)
# JOBS_CONCURRENCY=4
# JOBS_SCHEMA=graphile_worker
